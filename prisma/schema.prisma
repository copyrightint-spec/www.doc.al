generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  API_USER
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentStatus {
  DRAFT
  PENDING_SIGNATURE
  PARTIALLY_SIGNED
  COMPLETED
  ARCHIVED
}

enum SignatureStatus {
  PENDING
  SIGNED
  REJECTED
  EXPIRED
}

enum CertificateType {
  PERSONAL
  ORGANIZATION
  TSA
}

enum TimestampType {
  SINGLE_FILE
  SUBMITTED_HASH
  SIGNATURE
  COMPANY_SEAL
}

enum SealStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  REVOKED
}

enum SealType {
  COMPANY_SEAL
  OFFICIAL_STAMP
  INVOICE_SEAL
  CUSTOM
}

enum OtsStatus {
  PENDING
  CONFIRMED
}

enum VerificationCodeType {
  EMAIL
  TOTP
  SMS
}

enum OrganizationPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SigningRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum NotificationChannel {
  EMAIL
  SMS
  SMS_VOICE
}

enum CertAlertStatus {
  PENDING
  SENT
  ACKNOWLEDGED
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  PARTIALLY_SIGNED
  COMPLETED
  CANCELLED
}

// ==================== MODELS ====================

model User {
  id                           String              @id @default(cuid())
  email                        String              @unique
  name                         String
  password                     String?
  role                         UserRole            @default(USER)
  kycStatus                    KycStatus           @default(PENDING)
  kycDocumentUrl               String?
  kycMetadata                  Json?
  kycVerifiedAt                DateTime?
  totpSecret                   String?
  totpEnabled                  Boolean             @default(false)
  emailVerified                DateTime?
  image                        String?
  phone                        String?
  preferredNotificationChannel NotificationChannel @default(EMAIL)
  signatureData                Json? // Saved signature profiles (drawn, text, image)
  signatureStyle               String? // Active signature style: "draw" | "text" | "image"
  signatureTitle               String? // Title/position shown on signature block
  deactivatedAt                DateTime? // Soft-delete: KYC data retained until deactivation
  kycDataRetainedUntil         DateTime? // KYC data must be kept until user finishes using platform
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  documents         Document[]
  signatures        Signature[]
  certificates      Certificate[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  verificationCodes VerificationCode[]
  signingTemplates  SigningTemplate[]
  signingRequests   SigningRequest[]
  accounts          Account[]
  sessions          Session[]
  createdSeals      CompanySeal[]      @relation("SealCreator")
  appliedSeals      AppliedSeal[]      @relation("SealApplicant")
  contracts         Contract[]         @relation("ContractCreator")
  contractParties   ContractParty[]

  @@index([email])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id                  String           @id @default(cuid())
  name                String
  domain              String?          @unique
  logo                String?
  primaryColor        String?          @default("#dc2626")
  certificateTemplate String?
  apiQuota            Int              @default(100)
  plan                OrganizationPlan @default(FREE)
  webhookUrl          String?
  emailFromName       String?
  // Enterprise plan features
  verifiedAt          DateTime?
  verificationNotes   String?
  billingCycle        String?          @default("MONTHLY")
  planExpiresAt       DateTime?
  customQuotas        Json? // Override default plan quotas
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  users            User[]
  documents        Document[]
  certificates     Certificate[]
  apiKeys          ApiKey[]
  signingTemplates SigningTemplate[]
  companySeals     CompanySeal[]
  planQuotas       PlanQuota[]
  contracts        Contract[]

  @@index([domain])
}

model Document {
  id        String         @id @default(cuid())
  title     String
  fileName  String
  fileHash  String
  fileUrl   String
  fileSize  Int
  status    DocumentStatus @default(DRAFT)
  metadata  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  ownerId        String
  owner          User          @relation(fields: [ownerId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  signatures       Signature[]
  timestampEntries TimestampEntry[]
  signingRequests  SigningRequest[]
  appliedSeals     AppliedSeal[]

  @@index([fileHash])
  @@index([ownerId])
  @@index([status])
  @@index([organizationId])
}

model Signature {
  id                  String              @id @default(cuid())
  status              SignatureStatus     @default(PENDING)
  signerEmail         String
  signerName          String
  signedAt            DateTime?
  signatureImageUrl   String?
  position            Json?
  order               Int                 @default(0)
  token               String              @unique
  notificationChannel NotificationChannel @default(EMAIL)
  verificationSentAt  DateTime?
  lastReminderAt      DateTime?
  viewedAt            DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  documentId    String
  document      Document     @relation(fields: [documentId], references: [id])
  signerId      String?
  signer        User?        @relation(fields: [signerId], references: [id])
  certificateId String?
  certificate   Certificate? @relation(fields: [certificateId], references: [id])

  timestampEntries TimestampEntry[]

  @@index([documentId])
  @@index([signerId])
  @@index([token])
  @@index([signerEmail])
}

model Certificate {
  id                  String          @id @default(cuid())
  serialNumber        String          @unique
  subjectDN           String
  issuerDN            String
  publicKey           String          @db.Text
  encryptedPrivateKey String          @db.Text
  validFrom           DateTime
  validTo             DateTime
  revoked             Boolean         @default(false)
  revokedAt           DateTime?
  revokeReason        String?
  type                CertificateType @default(PERSONAL)
  autoRenew           Boolean         @default(false)
  renewalNotifiedAt   DateTime?
  createdAt           DateTime        @default(now())

  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  signatures    Signature[]
  renewalAlerts CertificateRenewalAlert[]
  companySeals  CompanySeal[]

  @@index([serialNumber])
  @@index([userId])
  @@index([type])
  @@index([validTo])
}

model CertificateRenewalAlert {
  id               String          @id @default(cuid())
  daysBeforeExpiry Int
  status           CertAlertStatus @default(PENDING)
  sentAt           DateTime?
  acknowledgedAt   DateTime?
  createdAt        DateTime        @default(now())

  certificateId String
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([certificateId, daysBeforeExpiry])
  @@index([status])
  @@index([certificateId])
}

model TimestampEntry {
  id                    String        @id @default(cuid())
  sequenceNumber        Int           @unique @default(autoincrement())
  fingerprint           String
  sequentialFingerprint String
  type                  TimestampType @default(SINGLE_FILE)
  serverTimestamp       DateTime      @default(now())
  btcTxId               String?
  btcBlockHeight        Int?
  btcBlockHash          String?
  otsProof              Bytes?
  otsStatus             OtsStatus     @default(PENDING)
  ipfsCid               String?
  // STAMLES / Polygon blockchain fields
  polygonTxHash         String?
  polygonBlockNumber    Int?
  stamlesBatchId        String?
  stamlesStatus         String?       @default("QUEUED") // QUEUED, BATCHED, CONFIRMED
  createdAt             DateTime      @default(now())

  documentId      String?
  document        Document?       @relation(fields: [documentId], references: [id])
  signatureId     String?
  signature       Signature?      @relation(fields: [signatureId], references: [id])
  previousEntryId String?         @unique
  previousEntry   TimestampEntry? @relation("TimestampChain", fields: [previousEntryId], references: [id])
  nextEntry       TimestampEntry? @relation("TimestampChain")
  appliedSeals    AppliedSeal[]

  @@index([sequenceNumber])
  @@index([fingerprint])
  @@index([otsStatus])
  @@index([serverTimestamp])
  @@index([stamlesStatus])
  @@index([stamlesBatchId])
}

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  permissions Json      @default("{}")
  rateLimit   Int       @default(100)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([key])
  @@index([userId])
}

model SigningTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  category        String?
  fields          Json
  signerRoles     Json?
  pdfmeTemplate   Json?
  pdfBaseUrl      String?
  previewImageUrl String?
  isPublic        Boolean  @default(false)
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  signingRequests SigningRequest[]

  @@index([userId])
  @@index([isPublic])
  @@index([category])
}

model SigningRequest {
  id              String               @id @default(cuid())
  status          SigningRequestStatus @default(PENDING)
  recipientEmails Json
  message         String?
  companyName     String?
  companyLogo     String?
  brandColor      String?              @default("#dc2626")
  expiresAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  templateId  String?
  template    SigningTemplate? @relation(fields: [templateId], references: [id])
  documentId  String
  document    Document         @relation(fields: [documentId], references: [id])
  requesterId String
  requester   User             @relation(fields: [requesterId], references: [id])
  contractId  String?          @unique
  contract    Contract?        @relation(fields: [contractId], references: [id])

  @@index([documentId])
  @@index([requesterId])
  @@index([status])
  @@index([companyName])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
}

model ContactRequest {
  id                        String   @id @default(cuid())
  companyName               String
  contactName               String
  email                     String
  phone                     String?
  position                  String?
  employees                 String
  industry                  String
  documentsPerMonth         String
  needsCertificateAuthority Boolean  @default(false)
  needsApiIntegration       Boolean  @default(false)
  needsWhiteLabel           Boolean  @default(false)
  needsCustomTemplates      Boolean  @default(false)
  currentSolution           String?
  message                   String?
  status                    String   @default("NEW")
  notes                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model VerificationCode {
  id        String               @id @default(cuid())
  code      String
  type      VerificationCodeType
  expiresAt DateTime
  used      Boolean              @default(false)
  createdAt DateTime             @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, type])
  @@index([code, type])
}

model CompanySeal {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        SealType @default(COMPANY_SEAL)

  // Seal design
  logoUrl        String?
  sealImageUrl   String?
  template       String  @default("official")
  primaryColor   String? @default("#0f172a")
  secondaryColor String? @default("#ffffff")
  borderText     String? // Text around the seal border (e.g. company name)
  centerText     String? // Center text (e.g. "VULE ZYRTARE")

  // eIDAS / ETSI compliance
  certificateId String?
  certificate   Certificate? @relation(fields: [certificateId], references: [id])
  eidasLevel    String       @default("ADVANCED") // BASIC, ADVANCED, QUALIFIED
  etsiPolicy    String?      @default("ETSI EN 319 411-1")

  // Status & Lifecycle
  status       SealStatus @default(ACTIVE)
  activatedAt  DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  revokeReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdByUserId String
  createdBy       User         @relation("SealCreator", fields: [createdByUserId], references: [id])

  appliedSeals AppliedSeal[]

  @@index([organizationId])
  @@index([status])
  @@index([certificateId])
}

model AppliedSeal {
  id String @id @default(cuid())

  // Document sealed
  documentId String
  document   Document @relation(fields: [documentId], references: [id])

  // Seal used
  sealId String
  seal   CompanySeal @relation(fields: [sealId], references: [id])

  // Application details
  appliedAt       DateTime @default(now())
  appliedByUserId String
  appliedBy       User     @relation("SealApplicant", fields: [appliedByUserId], references: [id])

  // Proof & verification
  sealImageSnapshot String? @db.Text // Base64 PNG of seal as applied
  certificationHash String  @unique
  verificationUrl   String
  qrCodeDataUri     String? @db.Text

  // Dual timestamps (server + OTS/Bitcoin)
  serverTimestamp  DateTime        @default(now())
  timestampEntryId String?
  timestampEntry   TimestampEntry? @relation(fields: [timestampEntryId], references: [id])

  // Position on PDF
  pageNumber Int   @default(1)
  xPosition  Float @default(50)
  yPosition  Float @default(50)

  // Cryptographic signature of the seal application
  digitalSignature String? @db.Text
  signedPayload    String? @db.Text // What was signed (JSON)

  createdAt DateTime @default(now())

  @@unique([documentId, sealId])
  @@index([documentId])
  @@index([sealId])
  @@index([certificationHash])
}

model PlanQuota {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Billing period
  periodStart  DateTime
  periodEnd    DateTime
  billingCycle String   @default("MONTHLY") // MONTHLY, YEARLY

  // Quota limits (set by plan)
  maxTimestamps     Int @default(100)
  maxSignatures     Int @default(50)
  maxSeals          Int @default(0)   // seal APPLICATIONS per period
  maxSealTemplates  Int @default(0)   // how many seal templates org can create (permanent, not per-period)
  maxApiCalls       Int @default(1000)
  maxDocuments      Int @default(100)
  maxUsers          Int @default(5)

  // Current usage
  usedTimestamps Int @default(0)
  usedSignatures Int @default(0)
  usedSeals      Int @default(0)
  usedApiCalls   Int @default(0)
  usedDocuments  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, periodStart, periodEnd])
  @@index([organizationId])
  @@index([periodEnd])
}

// ==================== CONTRACT BUILDER ====================

model LegalBasis {
  id             String   @id @default(cuid())
  title          String
  lawReference   String
  description    String   @db.Text
  suggestedTerms String   @db.Text
  category       String   @default("general")
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contracts ContractLegalBasis[]

  @@index([category])
  @@index([isActive])
}

model Contract {
  id             String         @id @default(cuid())
  contractNumber String         @unique
  title          String
  status         ContractStatus @default(DRAFT)
  termsHtml      String         @db.Text
  generatedAt    DateTime       @default(now())
  effectiveAt    DateTime?
  pdfUrl         String?
  documentHash   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  createdById    String
  createdBy      User          @relation("ContractCreator", fields: [createdById], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  parties        ContractParty[]
  legalBases     ContractLegalBasis[]
  signingRequest SigningRequest?

  @@index([createdById])
  @@index([status])
  @@index([organizationId])
  @@index([contractNumber])
}

model ContractParty {
  id          String    @id @default(cuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  partyNumber Int
  role        String
  fullName    String
  idNumber    String
  address     String
  phone       String    @default("")
  email       String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  signedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@unique([contractId, partyNumber])
  @@index([contractId])
  @@index([email])
}

model ContractLegalBasis {
  id           String     @id @default(cuid())
  contractId   String
  contract     Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  legalBasisId String
  legalBasis   LegalBasis @relation(fields: [legalBasisId], references: [id])

  @@unique([contractId, legalBasisId])
  @@index([contractId])
}

// ==================== EMAIL TRACKING ====================

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  BOUNCED
  FAILED
}

model EmailLog {
  id          String      @id @default(cuid())
  trackingId  String      @unique @default(cuid())
  from        String
  to          String
  subject     String
  status      EmailStatus @default(QUEUED)
  sentAt      DateTime?
  deliveredAt DateTime?
  bouncedAt   DateTime?
  failedAt    DateTime?
  errorMessage String?

  // Tracking
  openCount   Int         @default(0)
  firstOpenAt DateTime?
  lastOpenAt  DateTime?
  lastOpenIp  String?
  lastOpenUa  String?

  // Click tracking
  clickCount  Int         @default(0)
  firstClickAt DateTime?
  lastClickAt  DateTime?

  // Context - links email to document/signature/contract
  entityType  String?     // "Document", "Signature", "Contract", "Verification"
  entityId    String?
  userId      String?     // recipient user id if known

  metadata    Json?       // extra data (templateName, signerName, etc.)
  createdAt   DateTime    @default(now())

  opens       EmailOpen[]
  clicks      EmailClick[]

  @@index([trackingId])
  @@index([to])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model EmailOpen {
  id         String   @id @default(cuid())
  emailLogId String
  emailLog   EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  openedAt   DateTime @default(now())

  @@index([emailLogId])
  @@index([openedAt])
}

model EmailClick {
  id         String   @id @default(cuid())
  emailLogId String
  emailLog   EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  url        String
  ipAddress  String?
  userAgent  String?
  clickedAt  DateTime @default(now())

  @@index([emailLogId])
  @@index([clickedAt])
}
